<div class="container mx-auto px-4">

  <div class="max-w-3xl mx-auto mt-10">

    <!-- タイトル + 編集ボタン -->
    <div class="flex justify-between items-start mb-4">

      <h1 class="text-3xl font-bold text-gray-800">
        <%= @post.title %>
      </h1>

      <% if @post.owned_by?(current_user) %>
        <div class="flex gap-2">
          <%= link_to "編集",
              edit_post_path(@post),
              class: "px-3 py-1 text-sm bg-blue-500 text-white rounded hover:bg-blue-600" %>

          <%= link_to "削除",
              post_path(@post),
              data: { turbo_method: :delete, turbo_confirm: "本当に削除しますか？" },
              class: "px-3 py-1 text-sm bg-red-500 text-white rounded hover:bg-red-600" %>
        </div>
      <% end %>

    </div>

    <!-- 投稿日 -->
    <div class="text-gray-500 text-sm mb-6 text-right">
      <%= @post.created_at.strftime("%Y/%m/%d") %>
    </div>

    <!-- 本文 -->
    <div class="bg-white border border-gray-200 rounded-lg shadow-sm p-6 min-h-[200px]">

      <p class="text-gray-700 leading-relaxed whitespace-pre-line mb-3"><%= @post.body %></p>

      <div class="flex flex-wrap gap-2 mt-auto">
        <% @post.tags.each do |tag| %>
          <span class="text-xs bg-gray-100 text-gray-600 px-2 py-1 rounded">
            #<%= tag.name %>
          </span>
        <% end %>
      </div>

    </div>

    <!-- 戻るリンク -->
    <div class="mt-6">
      <%= link_to "← 投稿一覧に戻る",
          posts_path,
          class: "text-blue-600 hover:underline" %>
    </div>

  </div>

</div>