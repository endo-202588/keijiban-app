<div data-controller="char-count tag">

    <%= simple_form_for @post do |f| %>
    
    <%= f.input :title,
        label: "タイトル",
        label_html: { class: "block text-sm font-medium text-gray-700 mb-1" },
        input_html: { class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 p-2" } %>

    <%= f.input :body, as: :text,
        label: "本文",
        wrapper_html: { class: "mt-3" },
        label_html: { class: "block text-sm font-medium text-gray-700 mb-1" },
        input_html: { 
            rows: 6,
            data: {
                char_count_target: "input",
                action: "input->char-count#update"
            },
            class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 p-2" } %>

    <div
        class="text-xs text-gray-400 text-right mt-1"
        data-char-count-target="counter">
        0 / 200
    </div>

    <%= label_tag :tag_names, "タグ（スペース区切り）",
        class: "block text-sm font-medium text-gray-700 mt-3 mb-1" %>

    <div id="tag-list" class="flex flex-wrap gap-2 mb-2">
        <% @post.tags.each do |tag| %>
            <span class="bg-gray-200 px-2 py-1 rounded text-sm flex items-center">
            #<%= tag.name %>

            <button type="button"
                    class="ml-1 text-red-500"
                    data-action="click->tag#remove"
                    data-tag-name="<%= tag.name %>">
                ×
            </button>
            </span>
        <% end %>
    </div>

    <%= hidden_field_tag :tag_names,
        @post.tags.pluck(:name).join(" "),
        id: "tag-input-hidden" %>
    <input
        type="text"
        id="tag-input"
        placeholder="タグ追加（スペース区切り）"
        class="block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 p-2">

    <%= f.button :submit,
        "登録",
        class: "mt-3 w-full bg-blue-600 text-white py-2 rounded-lg hover:bg-blue-700" %>
    <% end %>

</div>