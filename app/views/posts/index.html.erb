<div class="container mx-auto">
  <h1 class="text-center mt-6">投稿一覧</h1>

  <div class="flex justify-end">
    <%= link_to "新規投稿", new_post_path,
        class: "bg-blue-600 text-white px-4 py-2 rounded-md hover:bg-blue-700" %>
  </div>

  <% @posts.each do | post | %>
    <div>
      <h3><%= post.title %></h3>
      <p><%= post.body %></p>
    </div>
  <% end %>
</div>
